<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- ========================================================
    CDN Libraries
    ======================================================== -->
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="<%= cdn.bootstrap %>">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="<%= cdn.bootstrapIcons %>">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="<%= cdn.fontAwesome %>">
    
    <title><%= title %></title>
    
    <style>
        /* ========================================================
        Custom Styles
        ======================================================== */
        
        /* Global */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #0d1117 0%, #161b22 100%);
            color: #e6edf3;
            min-height: 100vh;
        }
        
        /* Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        
        /* Header */
        .header {
            text-align: center;
            padding: 60px 20px;
            background: linear-gradient(135deg, #161b22 0%, #0d1117 100%);
            border-radius: 20px;
            border: 1px solid #30363d;
            margin-bottom: 40px;
        }
        
        .header .logo {
            font-size: 64px;
            animation: bounce 2s infinite;
        }
        
        .header h1 {
            font-size: 48px;
            font-weight: 800;
            background: linear-gradient(135deg, #58a6ff, #3fb950);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 20px 0 10px;
        }
        
        .header .subtitle {
            color: #8b949e;
            font-size: 18px;
            -webkit-text-fill-color: #8b949e;
        }
        
        .header .badge {
            margin-top: 20px;
            padding: 8px 20px;
            background: #238636;
            color: white;
            border-radius: 20px;
            display: inline-block;
            font-size: 14px;
        }
        
        /* Cards Grid */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 40px 0;
        }
        
        .feature-card {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 16px;
            padding: 30px 20px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .feature-card:hover {
            transform: translateY(-5px);
            border-color: #58a6ff;
            box-shadow: 0 8px 32px rgba(88, 166, 255, 0.15);
        }
        
        .feature-card .icon {
            font-size: 40px;
            margin-bottom: 15px;
            color: #58a6ff;
        }
        
        .feature-card h3 {
            font-size: 20px;
            margin-bottom: 10px;
            color: #e6edf3;
        }
        
        .feature-card p {
            color: #8b949e;
            font-size: 14px;
            line-height: 1.6;
        }
        
        /* Libraries Section */
        .libraries-section {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 16px;
            padding: 30px;
            margin: 40px 0;
        }
        
        .libraries-section h2 {
            margin-bottom: 20px;
            color: #58a6ff;
        }
        
        .library-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 15px;
        }
        
        .library-item {
            background: #0d1117;
            padding: 15px;
            border-radius: 10px;
            border: 1px solid #30363d;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .library-item .name {
            font-weight: 600;
            color: #e6edf3;
        }
        
        .library-item .version {
            font-size: 12px;
            color: #8b949e;
        }
        
        .library-item .type {
            font-size: 11px;
            padding: 2px 10px;
            border-radius: 12px;
            background: #21262d;
            color: #58a6ff;
        }
        
        /* Status Section */
        .status-section {
            background: #0d1117;
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 20px;
            margin: 20px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        .status-item {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #3fb950;
            animation: pulse 2s infinite;
        }
        
        /* Footer */
        .footer {
            text-align: center;
            padding: 30px 0;
            color: #8b949e;
            font-size: 14px;
            border-top: 1px solid #30363d;
            margin-top: 40px;
        }
        
        .footer a {
            color: #58a6ff;
            text-decoration: none;
        }
        
        .footer a:hover {
            text-decoration: underline;
        }
        
        /* Alpine.js Demo */
        .alpine-demo {
            background: #0d1117;
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 20px;
            margin: 20px 0;
        }
        
        /* Animations */
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .header h1 {
                font-size: 32px;
            }
            
            .header .logo {
                font-size: 48px;
            }
            
            .features-grid {
                grid-template-columns: 1fr;
            }
            
            .library-grid {
                grid-template-columns: 1fr;
            }
            
            .status-section {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- ====================================================
        HEADER
        ==================================================== -->
        
        <header class="header">
            <div class="logo">⚡</div>
            <h1><%= message %></h1>
            <p class="subtitle">Express.js with CDN Integration - Hello World</p>
            <div class="badge">
                <i class="fas fa-check-circle"></i>
                Server Running
            </div>
        </header>
        
        <!-- ====================================================
        STATUS
        ==================================================== -->
        
        <div class="status-section">
            <div class="status-item">
                <span class="status-dot"></span>
                <span>Status: <strong>Online</strong></span>
            </div>
            <div class="status-item">
                <i class="fas fa-clock"></i>
                <span>Time: <strong><%= timestamp %></strong></span>
            </div>
            <div class="status-item">
                <i class="fas fa-cloud"></i>
                <span>CDN: <strong>Enabled</strong></span>
            </div>
            <div class="status-item">
                <i class="fas fa-code"></i>
                <span>Env: <strong><%= nodeEnv %></strong></span>
            </div>
        </div>
        
        <!-- ====================================================
        FEATURES
        ==================================================== -->
        
        <div class="features-grid">
            <% features.forEach(feature => { %>
                <div class="feature-card">
                    <div class="icon">
                        <i class="fas <%= feature.icon %>"></i>
                    </div>
                    <h3><%= feature.title %></h3>
                    <p><%= feature.desc %></p>
                </div>
            <% }); %>
        </div>
        
        <!-- ====================================================
        ALPINE.JS DEMO
        ==================================================== -->
        
        <div class="alpine-demo" x-data="{ count: 0, message: 'Hello CDN!' }">
            <h3><i class="fas fa-code"></i> Alpine.js Demo</h3>
            <p style="color: #8b949e; margin: 10px 0;">
                Interactive demo using Alpine.js from CDN
            </p>
            
            <div style="display: flex; gap: 20px; flex-wrap: wrap; align-items: center;">
                <div>
                    <h2 x-text="count" style="font-size: 48px; color: #58a6ff;"></h2>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button 
                        @click="count++"
                        class="btn btn-success"
                    >
                        <i class="fas fa-plus"></i>
                    </button>
                    <button 
                        @click="count--"
                        class="btn btn-warning"
                    >
                        <i class="fas fa-minus"></i>
                    </button>
                    <button 
                        @click="count = 0"
                        class="btn btn-danger"
                    >
                        <i class="fas fa-redo"></i>
                    </button>
                </div>
                <div>
                    <input 
                        type="text" 
                        x-model="message"
                        placeholder="Type here..."
                        style="padding: 8px 15px; border-radius: 6px; border: 1px solid #30363d; background: #0d1117; color: #e6edf3;"
                    />
                    <p style="margin-top: 5px; color: #3fb950;">
                        <i class="fas fa-comment"></i>
                        <span x-text="message"></span>
                    </p>
                </div>
            </div>
        </div>
        
        <!-- ====================================================
        LIBRARIES
        ==================================================== -->
        
        <div class="libraries-section">
            <h2><i class="fas fa-cubes"></i> CDN Libraries</h2>
            <div class="library-grid">
                <% libraries.forEach(lib => { %>
                    <div class="library-item">
                        <div>
                            <span class="name"><%= lib.name %></span>
                            <span class="version">v<%= lib.version %></span>
                        </div>
                        <span class="type"><%= lib.type %></span>
                    </div>
                <% }); %>
            </div>
        </div>
        
        <!-- ====================================================
        FOOTER
        ==================================================== -->
        
        <footer class="footer">
            <p>
                <i class="fas fa-copyright"></i>
                2024 Express.js CDN Template
            </p>
            <p style="margin-top: 5px;">
                Built with <i class="fas fa-heart" style="color: #f85149;"></i>
                using Express.js & CDN
            </p>
            <p style="margin-top: 10px; font-size: 12px;">
                <a href="/">Home</a> |
                <a href="/about">About</a> |
                <a href="/health">Health</a>
            </p>
        </footer>
    </div>
    
    <!-- ====================================================
    CDN SCRIPTS
    ==================================================== -->
    
    <!-- Alpine.js -->
    <script src="<%= cdn.alpinejs %>" defer></script>
    
    <!-- HTMX -->
    <script src="<%= cdn.htmx %>" defer></script>
    
    <!-- Axios -->
    <script src="<%= cdn.axios %>" defer></script>
    
    <!-- Custom Script -->
    <script>
        console.log('🚀 Express.js Hello World with CDN');
        console.log('📦 CDN Libraries:');
        console.log('   - Bootstrap: <%= cdn.bootstrap %>');
        console.log('   - Alpine.js: <%= cdn.alpinejs %>');
        console.log('   - HTMX: <%= cdn.htmx %>');
        console.log('   - Axios: <%= cdn.axios %>');
        console.log('✅ All CDN libraries loaded!');
        
        // Test Axios
        axios.get('/health')
            .then(response => {
                console.log('📊 Health Check:', response.data);
            })
            .catch(error => {
                console.error('❌ Health Check Failed:', error);
            });
    </script>
</body>
</html>